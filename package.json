{
	"name": "jake-hatfield",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "npm run generate:item-images && vite build",
		"generate:item-images": "node scripts/generate-item-images.mjs",
		"preview": "vite preview",
		"test:unit": "vitest",
		"test:unit:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check --plugin-search-dir=. . && eslint .",
		"format": "prettier --write --plugin-search-dir=. ."
	},
	"devDependencies": {
		"@playwright/test": "^1.49.1",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-vercel": "^4.0.5",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.4",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/forms": "^0.5.9",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.6",
		"@types/jest": "^29.5.14",
		"@types/luxon": "^3.4.2",
		"@types/object-hash": "^3.0.6",
		"@types/pluralize": "^0.0.33",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"autoprefixer": "^10.4.20",
		"carbon-icons-svelte": "^12.6.0",
		"carbon-pictograms-svelte": "^12.3.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"jsdom": "^25.0.1",
		"mdsvex": "^0.12.3",
		"mdsvex-relative-images": "^1.0.3",
		"postcss-import": "^16.1.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"satori": "^0.12.0",
		"satori-html": "^0.3.2",
		"sharp": "^0.33.5",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.1",
		"tailwind-scrollbar": "^3.1.0",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
		"typescript": "^5.7.2",
		"vanilla-lazyload": "^19.1.3",
		"vite": "^5.4.11",
		"vite-imagetools": "^7.0.5",
		"vitest": "^2.1.8"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.1.0",
		"@fontsource/ibm-plex-sans": "^5.1.0",
		"@fontsource/permanent-marker": "^5.1.0",
		"@fontsource/silkscreen": "^5.1.0",
		"luxon": "^3.5.0",
		"object-hash": "^3.0.0",
		"pluralize": "^8.0.0",
		"reading-time-estimator": "^1.9.4",
		"svelte-inview": "^4.0.4",
		"title-case": "^4.3.2"
	}
}
